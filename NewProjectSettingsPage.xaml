<UserControl
    x:Class="BVCC.NewProjectSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bvcc="clr-namespace:BVCC"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    d:DesignHeight="500"
    d:DesignWidth="850"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="BackButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#88FFFFFF" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Storyboard x:Key="ShimmerStoryboard">
            <PointAnimation
                RepeatBehavior="Forever"
                Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.StartPoint)"
                From="-2,0"
                To="1,0"
                Duration="0:0:1.5" />
            <PointAnimation
                RepeatBehavior="Forever"
                Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.EndPoint)"
                From="-1,0"
                To="2,0"
                Duration="0:0:1.5" />
        </Storyboard>
        <Style x:Key="GhostCard" TargetType="Border">
            <Setter Property="Background" Value="#FF2A2A2A" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="BorderBrush" Value="#FF333333" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="GhostLine" TargetType="ContentControl">
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border
                            Background="#FF333333"
                            ClipToBounds="True"
                            CornerRadius="4">
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="-1,0" EndPoint="0,0">
                                        <GradientStop Offset="0" Color="Transparent" />
                                        <GradientStop Offset="0.5" Color="#1AFFFFFF" />
                                        <GradientStop Offset="1" Color="Transparent" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard Storyboard="{StaticResource ShimmerStoryboard}" />
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CreateButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0078D4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="12" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid">

                            <Border
                                x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">

                                <Grid ClipToBounds="True">

                                    <!--  Progress Fill  -->
                                    <Border
                                        x:Name="ProgressFill"
                                        HorizontalAlignment="Left"
                                        Background="#FF00A2FF">

                                        <Border.Width>
                                            <Binding Path="CreateProgress" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                        </Border.Width>
                                    </Border>

                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="1" />
                                </Grid>
                            </Border>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                            </Trigger>

                            <DataTrigger Binding="{Binding CreateProgress}" Value="100">
                                <Setter TargetName="ProgressFill" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding CreateProgress}" Value="0">
                                <Setter TargetName="ProgressFill" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding CreateProgress}" Value="0.1">
                                <Setter TargetName="ProgressFill" Property="Visibility" Value="Visible" />
                            </DataTrigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VersionComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF333333" />
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot">
                            <Border
                                x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                                <Grid>
                                    <ToggleButton
                                        Name="ToggleButton"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter
                                        Margin="12,0,25,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        IsHitTestVisible="False" />
                                    <Path
                                        x:Name="Arrow"
                                        Margin="0,0,10,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 3.5 4 L 7 0 Z"
                                        Fill="#88FFFFFF" />
                                </Grid>
                            </Border>
                            <Popup
                                Name="Popup"
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Fade">
                                <Border
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="200"
                                    Margin="0,4,0,0"
                                    Background="#FF222222"
                                    BorderBrush="#FF444444"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#25FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="Border">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="#FF333333" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="15,8"
                            Background="{TemplateBinding Background}"
                            CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Compact row style — single line, fits more items  -->
        <Style x:Key="ModernRepoItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="CardBorder"
                            Margin="0,0,0,3"
                            Padding="10,7"
                            Background="#FF252525"
                            BorderBrush="#FF333333"
                            BorderThickness="1"
                            CornerRadius="7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  CHECKBOX  -->
                                <Border
                                    x:Name="CheckBox"
                                    Grid.Column="0"
                                    Width="13"
                                    Height="13"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Background="#FF2A2A2A"
                                    BorderBrush="#FF555555"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                    <Path
                                        x:Name="CheckMark"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 1.5 5.5 L 4.5 8.5 L 10 2"
                                        Stroke="White"
                                        StrokeThickness="1.5"
                                        Visibility="Collapsed" />
                                </Border>

                                <!--  NAME  -->
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding Name}"
                                    TextTrimming="CharacterEllipsis" />

                                <!--  DESCRIPTION (muted, right side)  -->
                                <TextBlock
                                    Grid.Column="2"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#55FFFFFF"
                                    Text="{Binding Description}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FF0078D4" />
                                <Setter TargetName="CardBorder" Property="Background" Value="#FF1E2A3E" />
                                <Setter TargetName="CheckBox" Property="Background" Value="#FF0078D4" />
                                <Setter TargetName="CheckBox" Property="BorderBrush" Value="#FF0078D4" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FF444444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border
        Background="#FF1A1A1A"
        BorderBrush="#FF333333"
        BorderThickness="1"
        CornerRadius="15">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  HEADER  -->
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,20"
                Orientation="Horizontal">
                <Button
                    Click="BackBtn_Click"
                    Content="←"
                    Style="{StaticResource BackButton}" />
                <TextBlock
                    x:Name="HeaderText"
                    Margin="15,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="NEW PROJECT" />
            </StackPanel>

            <!--  PROJECT NAME + PATH  -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="11"
                        Foreground="#88FFFFFF"
                        Text="Project Name" />
                    <Border Style="{StaticResource InputBox}">
                        <TextBox
                            x:Name="ProjectNameBox"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            TextChanged="ProjectNameBox_TextChanged" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontSize="11"
                        Foreground="#88FFFFFF"
                        Text="Project Location" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource InputBox}">
                            <TextBox
                                x:Name="ProjectPathBox"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White" />
                        </Border>
                        <Button
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Background="#FF2A2A2A"
                            Click="BrowseProjectPath_Click"
                            Content="BROWSE"
                            Style="{StaticResource PillButton}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!--  REPO PANEL  -->
            <Border
                Grid.Row="2"
                Padding="15"
                Background="#FF1F1F1F"
                BorderBrush="#FF2D2D2D"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  TOOLBAR  -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Height="28"
                            Margin="0,0,10,0"
                            Background="#1AFFFFFF"
                            BorderBrush="#FF333333"
                            BorderThickness="1"
                            CornerRadius="14">
                            <Grid>
                                <TextBlock
                                    Margin="15,0"
                                    VerticalAlignment="Center"
                                    Foreground="#66FFFFFF"
                                    IsHitTestVisible="False"
                                    Text="Search repositories...">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=RepoSearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox
                                    x:Name="RepoSearchBox"
                                    Padding="15,0"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CaretBrush="White"
                                    Foreground="White"
                                    TextChanged="RepoSearchBox_TextChanged" />
                            </Grid>
                        </Border>

                        <ComboBox
                            x:Name="TemplateSelector"
                            Grid.Column="1"
                            Width="140"
                            Margin="0,0,10,0"
                            ItemsSource="{Binding RepoTemplates}"
                            SelectionChanged="TemplateSelector_SelectionChangedAsync"
                            Style="{StaticResource VersionComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                        </ComboBox>

                        <Border
                            Grid.Column="2"
                            Height="28"
                            Margin="0,0,10,0"
                            Background="#0AFFFFFF"
                            BorderBrush="#FF444444"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Grid>
                                <TextBlock
                                    Margin="8,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    Foreground="#44FFFFFF"
                                    IsHitTestVisible="False"
                                    Text="New template name...">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=TemplateNameBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox
                                    x:Name="TemplateNameBox"
                                    Padding="8,0"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CaretBrush="White"
                                    FontSize="11"
                                    Foreground="White" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <Button
                                Width="80"
                                Height="28"
                                Margin="0,0,6,0"
                                Background="#FF0078D4"
                                Click="CreateButton_Click"
                                Content="CREATE"
                                Style="{StaticResource PillButton}" />
                            <Button
                                Width="80"
                                Height="28"
                                Background="#FF4B4B"
                                Click="DeleteButton_Click"
                                Content="DELETE"
                                Style="{StaticResource PillButton}" />
                        </StackPanel>
                    </Grid>

                    <!--  BULK ACTION BAR  -->
                    <Border
                        x:Name="BulkActionBar"
                        Grid.Row="1"
                        Margin="0,0,0,8"
                        Padding="10,6"
                        Background="#FF1A2B3C"
                        BorderBrush="#FF0078D4"
                        BorderThickness="1"
                        CornerRadius="7"
                        Visibility="Collapsed">
                        <Grid>
                            <TextBlock
                                x:Name="SelectedCountText"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="0 selected" />
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">

                                <Button
                                    Height="30"
                                    MinWidth="110"
                                    Margin="0,0,6,0"
                                    Padding="10,4"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#FF2D2D2D"
                                    BorderBrush="#FF555555"
                                    BorderThickness="1"
                                    Click="SelectAll_Click"
                                    Content="Select All"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Style="{StaticResource PillButton}" />

                                <Button
                                    Height="30"
                                    MinWidth="110"
                                    Padding="10,4"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="#FF2D2D2D"
                                    BorderBrush="#FF555555"
                                    BorderThickness="1"
                                    Click="DeselectAll_Click"
                                    Content="Deselect All"
                                    FontSize="10"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Style="{StaticResource PillButton}" />

                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel
                        x:Name="RepoGhostLoading"
                        Grid.Row="2"
                        Visibility="Collapsed">

                        <Border
                            Margin="0,0,0,3"
                            Padding="10,7"
                            Style="{StaticResource GhostCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentControl
                                    Grid.Column="0"
                                    Width="13"
                                    Height="13"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="1"
                                    Width="180"
                                    Height="11"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="2"
                                    Width="120"
                                    Height="10"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource GhostLine}" />
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,0,0,3"
                            Padding="10,7"
                            Opacity="0.8"
                            Style="{StaticResource GhostCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentControl
                                    Grid.Column="0"
                                    Width="13"
                                    Height="13"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="1"
                                    Width="140"
                                    Height="11"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="2"
                                    Width="90"
                                    Height="10"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource GhostLine}" />
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,0,0,3"
                            Padding="10,7"
                            Opacity="0.6"
                            Style="{StaticResource GhostCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentControl
                                    Grid.Column="0"
                                    Width="13"
                                    Height="13"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="1"
                                    Width="160"
                                    Height="11"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="2"
                                    Width="150"
                                    Height="10"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource GhostLine}" />
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,0,0,3"
                            Padding="10,7"
                            Opacity="0.4"
                            Style="{StaticResource GhostCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentControl
                                    Grid.Column="0"
                                    Width="13"
                                    Height="13"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="1"
                                    Width="120"
                                    Height="11"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="2"
                                    Width="110"
                                    Height="10"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource GhostLine}" />
                            </Grid>
                        </Border>

                        <Border
                            Margin="0,0,0,3"
                            Padding="10,7"
                            Opacity="0.2"
                            Style="{StaticResource GhostCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentControl
                                    Grid.Column="0"
                                    Width="13"
                                    Height="13"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="1"
                                    Width="150"
                                    Height="11"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource GhostLine}" />
                                <ContentControl
                                    Grid.Column="2"
                                    Width="80"
                                    Height="10"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource GhostLine}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                    <!--  REPO LIST  -->
                    <ListBox
                        x:Name="RepoList"
                        Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemContainerStyle="{StaticResource ModernRepoItem}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectionChanged="RepoList_SelectionChanged"
                        SelectionMode="Multiple" />
                </Grid>
            </Border>

            <!--  FOOTER  -->
            <Grid Grid.Row="3" Margin="0,20,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="10"
                        Foreground="#44FFFFFF"
                        Text="Select repositories to bundle into the project." />
                    <TextBlock
                        FontSize="10"
                        Foreground="#44FFFFFF"
                        Text="Saved presets appear in the dropdown above." />
                </StackPanel>
                <Button
                    x:Name="CreateBtn"
                    Width="200"
                    Height="42"
                    HorizontalAlignment="Right"
                    Click="CreateProject_Click"
                    Content="CREATE PROJECT"
                    FontSize="12"
                    Style="{StaticResource CreateButton}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
