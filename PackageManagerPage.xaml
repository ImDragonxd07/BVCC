<UserControl
    x:Class="BVCC.PackageManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BVCC"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <UserControl.Resources>
        <local:MultiplierConverter x:Key="MultiplierConverter" />
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <local:ActionToColorConverter x:Key="ActionToColorConverter" />
        <local:IsProgressingConverter x:Key="IsProgressingConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter
                                x:Name="Content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1.0"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.5"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Content" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Storyboard x:Key="PulseAnimation">
            <DoubleAnimation
                AutoReverse="True"
                RepeatBehavior="Forever"
                Storyboard.TargetProperty="Opacity"
                From="1.0"
                To="0.4"
                Duration="0:0:0.8" />
        </Storyboard>
        <LinearGradientBrush x:Key="ShimmerBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Offset="0" Color="#FF2A2A2A" />
            <GradientStop Offset="0.5" Color="#FF3A3A3A" />
            <GradientStop Offset="1" Color="#FF2A2A2A" />
        </LinearGradientBrush>
        <Storyboard x:Key="ShimmerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[1].Offset"
                From="-1"
                To="2"
                Duration="0:0:1.2" />
        </Storyboard>
        <Style x:Key="HeroPillButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonContainer" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <Border
                                x:Name="BackBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                CornerRadius="14" />
                            <ContentPresenter
                                Margin="15,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Panel.ZIndex="1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonContainer" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.05" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  INSTALL button  -->
        <Style x:Key="InstallButton" TargetType="Button">
            <Setter Property="Background" Value="#FF007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid">
                            <Border
                                x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid ClipToBounds="True">
                                    <Border
                                        x:Name="ProgressFill"
                                        HorizontalAlignment="Left"
                                        Background="#FF0099FF"
                                        CornerRadius="3"
                                        Visibility="Collapsed">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource MultiplierConverter}">
                                                <Binding Path="InstallProgress" />
                                                <Binding ElementName="RootGrid" Path="ActualWidth" />
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="1" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ProgressingControl, Converter={StaticResource IsProgressingConverter}, ConverterParameter=Install}" Value="True" />
                                    <Condition Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ProgressFill" Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#CC007ACC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  UPDATE button  -->
        <Style x:Key="UpdateButton" TargetType="Button">
            <Setter Property="Background" Value="#FF007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid">
                            <Border
                                x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid ClipToBounds="True">
                                    <Border
                                        x:Name="ProgressFill"
                                        HorizontalAlignment="Left"
                                        Background="#FF0099FF"
                                        CornerRadius="3"
                                        Visibility="Collapsed">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource MultiplierConverter}">
                                                <Binding Path="InstallProgress" />
                                                <Binding ElementName="RootGrid" Path="ActualWidth" />
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="1" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ProgressingControl, Converter={StaticResource IsProgressingConverter}, ConverterParameter=Update}" Value="True" />
                                    <Condition Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ProgressFill" Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#CC007ACC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--  REMOVE button  -->
        <Style x:Key="RemoveButton" TargetType="Button">
            <Setter Property="Background" Value="#FF444444" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid">
                            <Border
                                x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid ClipToBounds="True">
                                    <Border
                                        x:Name="ProgressFill"
                                        HorizontalAlignment="Left"
                                        Background="#FFFF4444"
                                        CornerRadius="3"
                                        Visibility="Collapsed">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource MultiplierConverter}">
                                                <Binding Path="InstallProgress" />
                                                <Binding ElementName="RootGrid" Path="ActualWidth" />
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                    <ContentPresenter
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="1" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ProgressingControl, Converter={StaticResource IsProgressingConverter}, ConverterParameter=Remove}" Value="True" />
                                    <Condition Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ProgressFill" Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#CC444444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="PackageFrame"
                            Margin="0,0,0,8"
                            Padding="15,10"
                            Background="#FF2A2A2A"
                            BorderBrush="#FF333333"
                            BorderThickness="1"
                            CornerRadius="10"
                            Opacity="1.0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                <Setter TargetName="PackageFrame" Property="Background" Value="#FF1E1E1E" />
                                <Setter TargetName="PackageFrame" Property="BorderBrush" Value="#FF252525" />
                                <Setter TargetName="PackageFrame" Property="Opacity" Value="0.7" />
                            </DataTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="PackageFrame" Property="BorderBrush" Value="#FF0099FF" />
                                <Setter TargetName="PackageFrame" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VersionComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#FF333333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF444444" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" ClipToBounds="True">
                            <Border
                                x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid ClipToBounds="True">
                                    <Border
                                        x:Name="ProgressFill"
                                        HorizontalAlignment="Left"
                                        Background="#FFAAAAAA"
                                        CornerRadius="3"
                                        Visibility="Collapsed">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource MultiplierConverter}">
                                                <Binding Path="InstallProgress" />
                                                <Binding ElementName="ComboRoot" Path="ActualWidth" />
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                    <ToggleButton
                                        Name="ToggleButton"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        IsEnabled="{Binding IsActionProgressing, Converter={StaticResource InverseBooleanConverter}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter
                                        Margin="8,0,25,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="1"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        IsHitTestVisible="False" />
                                    <Path
                                        x:Name="Arrow"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="1"
                                        Data="M 0 0 L 3.5 4 L 7 0 Z"
                                        Fill="#88FFFFFF" />
                                </Grid>
                            </Border>
                            <Popup
                                Name="Popup"
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom">
                                <Border
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    Background="#FF222222"
                                    BorderBrush="#FF444444"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <Grid ClipToBounds="True">
                                        <Border
                                            Height="3"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="0,0,3,3"
                                            Visibility="{Binding ProgressingControl, Converter={StaticResource IsProgressingConverter}, ConverterParameter=Version}">
                                            <Border.Background>
                                                <Binding Converter="{StaticResource ActionToColorConverter}" Path="CurrentAction" />
                                            </Border.Background>
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource MultiplierConverter}">
                                                    <Binding Path="InstallProgress" />
                                                    <Binding ElementName="ComboRoot" Path="ActualWidth" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                        <ScrollViewer
                                            MaxHeight="200"
                                            Margin="2"
                                            Panel.ZIndex="1">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ProgressingControl, Converter={StaticResource IsProgressingConverter}, ConverterParameter=Version}" Value="True" />
                                    <Condition Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ProgressFill" Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding IsActionProgressing}" Value="True">
                                <Setter Property="Background" Value="#FF1A1A1A" />
                                <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="#FF1A1A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border
            Grid.Row="0"
            Padding="20"
            Background="#FF1A1A1A"
            BorderBrush="#FF333333"
            BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Button
                            x:Name="BackBtn"
                            Margin="0,0,15,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BackBtn_Click"
                            Content="←"
                            FontSize="18"
                            Foreground="White"
                            Style="{StaticResource TitleBarButton}" />
                        <TextBlock
                            x:Name="ProjectTitleText"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Project Title" />
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Button
                            x:Name="UnityVersionText"
                            Width="90"
                            Margin="0,0,8,0"
                            Background="#FF333333"
                            Content="Version"
                            IsHitTestVisible="False"
                            Style="{StaticResource HeroPillButton}" />

                        <Button
                            x:Name="BackupsBtn"
                            Width="85"
                            Margin="0,0,8,0"
                            Background="#FF333333"
                            Click="BackupsBtn_Click"
                            Content="Backups"
                            Style="{StaticResource HeroPillButton}" />

                        <Button
                            x:Name="LaunchProjectBtn"
                            Width="85"
                            Background="#FF007ACC"
                            Click="LaunchProjectBtn_Click"
                            Content="LAUNCH"
                            Style="{StaticResource HeroPillButton}" />

                        <Button
                            x:Name="MoreBtn"
                            Width="36"
                            Height="32"
                            Margin="8,0,0,0"
                            Background="#FF333333"
                            Click="MoreBtn_Click"
                            Style="{StaticResource HeroPillButton}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="10"
                                Text="&#xE70D;" />
                        </Button>

                        <Popup
                            x:Name="MorePopup"
                            AllowsTransparency="True"
                            HorizontalOffset="-114"
                            Placement="Bottom"
                            PlacementTarget="{Binding ElementName=MoreBtn}"
                            StaysOpen="False">
                            <Border
                                Width="150"
                                Margin="0,4,0,0"
                                Background="#FF1E1E1E"
                                BorderBrush="#FF333333"
                                BorderThickness="1"
                                CornerRadius="10">
                                <StackPanel Margin="6">
                                    <StackPanel.Resources>
                                        <Style BasedOn="{StaticResource TitleBarButton}" TargetType="Button">
                                            <Setter Property="Height" Value="32" />
                                            <Setter Property="Padding" Value="12,0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF333333" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Resources>

                                    <Button
                                        x:Name="OpenFilePathBtn"
                                        Click="OpenFilePath_Click"
                                        Content="Open Path" />

                                    <Button
                                        x:Name="CloneProjectBtn"
                                        Click="CloneProjectBtn_Click"
                                        Content="Clone Project" />

                                    <Button
                                        x:Name="RemoveProjectBtnMenu"
                                        Click="RemoveProjectBtn_Click"
                                        Content="Remove Project"
                                        Foreground="#FFFF6666" />

                                    <Button
                                        x:Name="DeleteProjectBtn"
                                        Click="DeleteProjectBtn_Click"
                                        Content="Delete Project"
                                        Foreground="#FFFF6666" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="UpdateAll"
                        Grid.Column="0"
                        Width="100"
                        Margin="0,0,8,0"
                        Background="#FF007ACC"
                        Click="UpdateAll_Click"
                        Content="UPDATE ALL"
                        Style="{StaticResource HeroPillButton}" />
                    <Button
                        x:Name="ReinstallAll"
                        Grid.Column="1"
                        Width="110"
                        Background="#FF333333"
                        Click="ReinstallAll_Click"
                        Content="REINSTALL ALL"
                        Style="{StaticResource HeroPillButton}" />
                    <Border
                        Grid.Column="2"
                        Height="28"
                        Margin="10,0,0,0"
                        Background="#0DFFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid>
                            <TextBlock
                                Margin="10,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#44FFFFFF"
                                IsHitTestVisible="False"
                                Text="Search packages...">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox
                                x:Name="SearchBox"
                                Margin="10,0"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                CaretBrush="White"
                                FontSize="11"
                                Foreground="White"
                                TextChanged="SearchBox_TextChanged" />
                        </Grid>
                    </Border>
                    <Border
                        x:Name="BulkProgressBorder"
                        Grid.Column="3"
                        Width="220"
                        Height="28"
                        Margin="8,0,0,0"
                        Background="#0DFFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        ClipToBounds="True"
                        CornerRadius="8"
                        Visibility="Collapsed">
                        <Grid>
                            <Border
                                x:Name="BulkProgressFill"
                                Width="0"
                                HorizontalAlignment="Left"
                                Background="#FF007ACC"
                                CornerRadius="8" />
                            <TextBlock
                                x:Name="BulkProgressText"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White" />
                        </Grid>
                    </Border>
                </Grid>
                <Grid Margin="0,15,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Padding="2" CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    x:Name="FilterAll"
                                    Width="Auto"
                                    Padding="14,4"
                                    Background="White"
                                    BorderThickness="0"
                                    Click="FilterTab_Click"
                                    Content="All"
                                    Foreground="Black"
                                    Style="{StaticResource HeroPillButton}"
                                    Tag="All" />
                                <Button
                                    x:Name="FilterInstalled"
                                    Width="Auto"
                                    Padding="14,4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="FilterTab_Click"
                                    Content="Installed"
                                    Foreground="#99FFFFFF"
                                    Style="{StaticResource HeroPillButton}"
                                    Tag="Installed" />
                                <Button
                                    x:Name="FilterNotInstalled"
                                    Width="Auto"
                                    Padding="14,4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="FilterTab_Click"
                                    Content="Not Installed"
                                    Foreground="#99FFFFFF"
                                    Style="{StaticResource HeroPillButton}"
                                    Tag="NotInstalled" />
                                <Button
                                    x:Name="FilterUpdates"
                                    Width="Auto"
                                    Padding="14,4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="FilterTab_Click"
                                    Content="Updates"
                                    Foreground="#99FFFFFF"
                                    Style="{StaticResource HeroPillButton}"
                                    Tag="Updates" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="#44FFFFFF"
                            Text="Sort:" />
                        <Button
                            x:Name="SortName"
                            Margin="0,0,12,0"
                            Click="SortBtn_Click"
                            Content="Name"
                            FontSize="11"
                            Foreground="White"
                            Opacity="1.0"
                            Style="{StaticResource TitleBarButton}"
                            Tag="Name" />
                        <Button
                            x:Name="SortStatus"
                            Margin="0,0,12,0"
                            Click="SortBtn_Click"
                            Content="Status"
                            FontSize="11"
                            Foreground="White"
                            Opacity="0.4"
                            Style="{StaticResource TitleBarButton}"
                            Tag="Status" />
                        <Button
                            x:Name="SortVersion"
                            Click="SortBtn_Click"
                            Content="Version"
                            FontSize="11"
                            Foreground="White"
                            Opacity="0.4"
                            Style="{StaticResource TitleBarButton}"
                            Tag="Version" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <ListBox
            x:Name="PackageListBox"
            Grid.Row="1"
            Margin="15"
            HorizontalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            ScrollViewer.CanContentScroll="False"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <Border Padding="15,5">
                            <Grid Margin="0,5" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!--  Top row: Name + warning  -->
                                    <StackPanel
                                        Grid.Row="0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">

                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Medium"
                                            Foreground="White"
                                            Text="{Binding Name}" />

                                        <TextBlock
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="Red"
                                            Text=" ⚠"
                                            Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock.ToolTip>
                                                <ToolTip MaxWidth="250">
                                                    <TextBlock Text="{Binding IncompatibleReason}" TextWrapping="Wrap" />
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>

                                    </StackPanel>

                                    <!--  Bottom row: Version  -->
                                    <TextBlock
                                        Grid.Row="1"
                                        Margin="0,2,0,0"
                                        FontSize="10"
                                        Foreground="#66FFFFFF"
                                        Text="{Binding VersionInfo}" />
                                </Grid>
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <ComboBox
                                        Width="110"
                                        Margin="0,0,10,0"
                                        ItemsSource="{Binding VersionList}"
                                        SelectedItem="{Binding SelectedVersion}"
                                        SelectionChanged="VersionSelector_SelectionChanged"
                                        Style="{DynamicResource VersionComboBox}" />
                                    <Button
                                        Width="85"
                                        Margin="0,0,8,0"
                                        Click="PackageUpdate_Click"
                                        Content="UPDATE">
                                        <Button.Style>
                                            <Style BasedOn="{StaticResource UpdateButton}" TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Grid>
                                        <Button
                                            Width="85"
                                            Click="InstallPackage_Click"
                                            Content="INSTALL">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource InstallButton}" TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button
                                            Width="85"
                                            Click="RemovePackage_Click"
                                            Content="REMOVE"
                                            IsEnabled="{Binding IsADependency, Converter={StaticResource InverseBooleanConverter}}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource RemoveButton}" TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <StackPanel Visibility="{Binding HasDependencies, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ToggleButton
                                x:Name="DepToggle"
                                HorizontalAlignment="Stretch"
                                Background="Transparent">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border
                                            x:Name="ToggleBorder"
                                            Padding="10,6"
                                            Background="#FF121212"
                                            BorderBrush="#1AFFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                            <Grid>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="#66FFFFFF"
                                                    Text="DEPENDENCIES" />
                                                <Path
                                                    x:Name="ArrowPath"
                                                    Margin="0,0,10,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Data="M 0 0 L 4 4 L 8 0"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Stroke="#44FFFFFF"
                                                    StrokeThickness="2">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0" />
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="CornerRadius" Value="10,10,0,0" />
                                                <Setter TargetName="ToggleBorder" Property="BorderThickness" Value="1,1,1,0" />
                                                <Setter TargetName="ArrowPath" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#FF181818" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#44FFFFFF" />
                                                <Setter TargetName="ArrowPath" Property="Stroke" Value="#CCFFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Border
                                x:Name="DependencyDrawer"
                                Margin="0"
                                Background="#FF121212"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1,0,1,1"
                                CornerRadius="0,0,10,10"
                                RenderTransformOrigin="0.5,0">
                                <Border.LayoutTransform>
                                    <ScaleTransform ScaleY="0" />
                                </Border.LayoutTransform>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=DepToggle}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="LayoutTransform.ScaleY"
                                                                To="1"
                                                                Duration="0:0:0.2">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <QuadraticEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="LayoutTransform.ScaleY"
                                                                To="0"
                                                                Duration="0:0:0.15" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ItemsControl Padding="0,5,0,10" ItemsSource="{Binding Dependencies}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid
                                                x:Name="DepRow"
                                                Height="38"
                                                Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <Ellipse
                                                        x:Name="StatusDot"
                                                        Width="6"
                                                        Height="6"
                                                        Margin="0,0,15,0"
                                                        VerticalAlignment="Center"
                                                        Fill="#33FFFFFF" />
                                                    <TextBlock
                                                        FontSize="12"
                                                        FontWeight="Medium"
                                                        Foreground="#CCFFFFFF"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Margin="12,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="10"
                                                        Foreground="#44FFFFFF"
                                                        Text="{Binding VersionInfo}" />
                                                </StackPanel>
                                                <StackPanel
                                                    Grid.Column="2"
                                                    Margin="0,0,20,0"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <Button
                                                        x:Name="UpdateBtn"
                                                        Width="75"
                                                        Height="24"
                                                        Click="PackageUpdate_Click"
                                                        Content="UPDATE"
                                                        FontSize="9"
                                                        Style="{StaticResource UpdateButton}"
                                                        Visibility="Collapsed" />
                                                    <TextBlock
                                                        x:Name="StatusLabel"
                                                        VerticalAlignment="Center"
                                                        FontSize="9"
                                                        FontWeight="Bold"
                                                        Visibility="Collapsed" />
                                                </StackPanel>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Compatible">
                                                    <Setter TargetName="StatusDot" Property="Fill" Value="#FF4CAF50" />
                                                    <Setter TargetName="StatusLabel" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="StatusLabel" Property="Text" Value="UP TO DATE" />
                                                    <Setter TargetName="StatusLabel" Property="Foreground" Value="#44FFFFFF" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="UpdateAvailable">
                                                    <Setter TargetName="StatusDot" Property="Fill" Value="#FF2196F3" />
                                                    <Setter TargetName="UpdateBtn" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Incompatible">
                                                    <Setter TargetName="StatusDot" Property="Fill" Value="#FFFF9800" />
                                                    <Setter TargetName="StatusLabel" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="StatusLabel" Property="Text" Value="INCOMPATIBLE" />
                                                    <Setter TargetName="StatusLabel" Property="Foreground" Value="#FFFF9800" />
                                                    <Setter TargetName="DepRow" Property="ToolTip" Value="{Binding IncompatibleReason}" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="DepRow" Property="Background" Value="#0AFFFFFF" />
                                                </Trigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Grid
            x:Name="LoadingOverlay"
            Grid.Row="1"
            Background="#FF1A1A1A"
            Visibility="Collapsed">
            <Grid.Resources>
                <Storyboard x:Key="ShimmerStoryboard">
                    <PointAnimation
                        RepeatBehavior="Forever"
                        Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.StartPoint)"
                        From="-2,0"
                        To="1,0"
                        Duration="0:0:1.5" />
                    <PointAnimation
                        RepeatBehavior="Forever"
                        Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.EndPoint)"
                        From="-1,0"
                        To="2,0"
                        Duration="0:0:1.5" />
                </Storyboard>
                <Style x:Key="GhostCard" TargetType="Border">
                    <Setter Property="Background" Value="#FF2A2A2A" />
                    <Setter Property="CornerRadius" Value="10" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="Padding" Value="15,10" />
                    <Setter Property="BorderBrush" Value="#FF333333" />
                    <Setter Property="BorderThickness" Value="1" />
                </Style>
                <Style x:Key="GhostLine" TargetType="ContentControl">
                    <Setter Property="IsTabStop" Value="False" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ContentControl">
                                <Border
                                    Background="#FF333333"
                                    ClipToBounds="True"
                                    CornerRadius="4">
                                    <Border>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="-1,0" EndPoint="0,0">
                                                <GradientStop Offset="0" Color="Transparent" />
                                                <GradientStop Offset="0.5" Color="#1AFFFFFF" />
                                                <GradientStop Offset="1" Color="Transparent" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard Storyboard="{StaticResource ShimmerStoryboard}" />
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>
            <StackPanel Margin="15,15,15,0">
                <Border Style="{StaticResource GhostCard}">
                    <Grid Margin="15,0" VerticalAlignment="Center">
                        <StackPanel>
                            <ContentControl
                                Width="200"
                                Height="12"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostLine}" />
                            <ContentControl
                                Width="300"
                                Height="9"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostLine}" />
                        </StackPanel>
                        <ContentControl
                            Width="80"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource GhostLine}" />
                    </Grid>
                </Border>
                <Border Opacity="0.8" Style="{StaticResource GhostCard}">
                    <Grid Margin="15,0" VerticalAlignment="Center">
                        <StackPanel>
                            <ContentControl
                                Width="160"
                                Height="12"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostLine}" />
                            <ContentControl
                                Width="240"
                                Height="9"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostLine}" />
                        </StackPanel>
                        <ContentControl
                            Width="80"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource GhostLine}" />
                    </Grid>
                </Border>
                <Border Opacity="0.6" Style="{StaticResource GhostCard}">
                    <Grid Margin="15,0" VerticalAlignment="Center">
                        <StackPanel>
                            <ContentControl
                                Width="180"
                                Height="12"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostLine}" />
                            <ContentControl
                                Width="270"
                                Height="9"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostLine}" />
                        </StackPanel>
                        <ContentControl
                            Width="80"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource GhostLine}" />
                    </Grid>
                </Border>
                <Border Opacity="0.4" Style="{StaticResource GhostCard}">
                    <Grid Margin="15,0" VerticalAlignment="Center">
                        <StackPanel>
                            <ContentControl
                                Width="130"
                                Height="12"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostLine}" />
                            <ContentControl
                                Width="210"
                                Height="9"
                                HorizontalAlignment="Left"
                                Style="{StaticResource GhostLine}" />
                        </StackPanel>
                        <ContentControl
                            Width="80"
                            Height="24"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource GhostLine}" />
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
