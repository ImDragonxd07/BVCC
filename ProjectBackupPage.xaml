<UserControl
    x:Class="BVCC.ProjectBackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BVCC"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <local:ProgressWidthConverter x:Key="ProgressWidthConverter" />
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter
                                x:Name="Content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1.0"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.5"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Content" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#FF1A1A1A" />
            <Setter Property="Height" Value="4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" ClipToBounds="True">

                            <Border Background="{TemplateBinding Background}" CornerRadius="2" />

                            <Grid x:Name="DeterminateRoot">
                                <Canvas>
                                    <Rectangle
                                        x:Name="ProgressFill"
                                        Height="4"
                                        Fill="#FF0078D4"
                                        RadiusX="2"
                                        RadiusY="2">
                                        <Rectangle.Width>
                                            <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                                <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource TemplatedParent}" />
                                            </MultiBinding>
                                        </Rectangle.Width>
                                    </Rectangle>
                                </Canvas>
                            </Grid>

                            <Grid x:Name="IndeterminateRoot" Visibility="Collapsed">
                                <Rectangle
                                    x:Name="StretchBar"
                                    Width="60"
                                    Height="4"
                                    HorizontalAlignment="Left"
                                    RadiusX="2"
                                    RadiusY="2">

                                    <Rectangle.Fill>
                                        <RadialGradientBrush x:Name="GlowBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                            <GradientStop Offset="0.0" Color="#FF60CDFF" />
                                            <GradientStop Offset="0.6" Color="#FF0078D4" />
                                            <GradientStop Offset="1.0" Color="Transparent" />
                                        </RadialGradientBrush>
                                    </Rectangle.Fill>

                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="StretchScale" CenterX="30" ScaleX="1" />
                                            <TranslateTransform x:Name="StretchTranslate" X="-60" />
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="IndeterminateRoot" Property="Visibility" Value="Visible" />
                                <Setter TargetName="DeterminateRoot" Property="Visibility" Value="Collapsed" />

                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">

                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="StretchBar" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="-80" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.4,0 0.6,1"
                                                    KeyTime="0:0:2.0"
                                                    Value="800" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:2.8" Value="800" />
                                            </DoubleAnimationUsingKeyFrames>

                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="StretchBar" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.2" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.1,0.9 0.2,1.0"
                                                    KeyTime="0:0:1.0"
                                                    Value="2.5" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.7,0 1,0.3"
                                                    KeyTime="0:0:2.0"
                                                    Value="0.2" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:2.8" Value="0.2" />
                                            </DoubleAnimationUsingKeyFrames>

                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowBrush" Storyboard.TargetProperty="RadiusX">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.5">
                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                        <CircleEase EasingMode="EaseOut" />
                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                </EasingDoubleKeyFrame>
                                                <LinearDoubleKeyFrame KeyTime="0:0:2.0" Value="0.5" />
                                            </DoubleAnimationUsingKeyFrames>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>

                            <Trigger Property="IsIndeterminate" Value="False">
                                <Setter TargetName="IndeterminateRoot" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="DeterminateRoot" Property="Visibility" Value="Visible" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15,0,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <Button
                    x:Name="BackBtn"
                    Margin="0,0,15,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BackBtn_Click"
                    Content="←"
                    FontSize="20"
                    Foreground="#88FFFFFF"
                    Style="{StaticResource TitleBarButton}" />
                <TextBlock
                    x:Name="ProjectNameText"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="PROJECT_NAME" />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Border
                    Width="220"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="#FF1E1E1E"
                    BorderBrush="#FF333333"
                    BorderThickness="1"
                    CornerRadius="16">
                    <TextBox
                        x:Name="BackupNameInput"
                        Padding="15,0"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="11"
                        Foreground="White"
                        GotFocus="BackupNameInput_GotFocus"
                        LostFocus="BackupNameInput_LostFocus"
                        Text="Backup Name..." />
                </Border>
                <Button
                    Width="110"
                    Height="32"
                    Background="#FF0078D4"
                    Click="CreateBackup_Click"
                    Content="+ CREATE"
                    Style="{StaticResource PillButton}" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Background="#FF121212"
            BorderBrush="#FF252525"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox
                    x:Name="BackupHistoryList"
                    Grid.Row="0"
                    Padding="12"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border
                                            x:Name="OuterBorder"
                                            Margin="0,0,0,10"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="10"
                                            SnapsToDevicePixels="True">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="OuterBorder" Property="Background" Value="#08FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,4"
                                Padding="16"
                                BorderBrush="#1AFFFFFF"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#12FFFFFF" />
                                        <GradientStop Offset="1" Color="#08FFFFFF" />
                                    </LinearGradientBrush>
                                </Border.Background>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        Grid.Column="0"
                                        Width="40"
                                        Height="40"
                                        Margin="0,0,15,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="OpenBackupPath_Click"
                                        Cursor="Hand"
                                        ToolTip="Open File Location">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="22"
                                            Foreground="#FF60CDFF"
                                            Opacity="0.7"
                                            Text="" />
                                    </Button>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="Medium"
                                            Foreground="White"
                                            Opacity="0.9"
                                            Text="{Binding Name}" />
                                        <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="White"
                                                Opacity="0.4"
                                                Text="{Binding date, StringFormat={}{0:MMM dd\, yyyy HH:mm}}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            Width="70"
                                            Height="26"
                                            Margin="0,0,8,0"
                                            Background="#15FFFFFF"
                                            Click="CloneBackup_Click"
                                            Content="CLONE"
                                            FontSize="10"
                                            Style="{StaticResource PillButton}" />

                                        <Button
                                            Width="80"
                                            Height="26"
                                            Margin="0,0,8,0"
                                            Background="#2060CDFF"
                                            Click="RestoreBackup_Click"
                                            Content="RESTORE"
                                            FontSize="10"
                                            FontWeight="Bold"
                                            Foreground="#FF60CDFF"
                                            Style="{StaticResource PillButton}" />

                                        <Button
                                            Width="75"
                                            Height="26"
                                            Background="#20FF4B4B"
                                            Click="DeleteBackup_Click"
                                            Content="REMOVE"
                                            FontSize="10"
                                            Foreground="#FFFF7B7B"
                                            Style="{StaticResource PillButton}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ProgressBar
                    x:Name="LoadingBar"
                    Grid.Row="1"
                    Width="Auto"
                    Height="4"
                    HorizontalAlignment="Stretch"
                    IsIndeterminate="True"
                    Style="{StaticResource ModernProgressBar}"
                    ValueChanged="LoadingBar_ValueChanged"
                    Value="65" />
            </Grid>
        </Border>
    </Grid>
</UserControl>