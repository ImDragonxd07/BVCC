<Window
    x:Class="BVCC.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BVCC"
    Width="900"
    Height="550"
    MinWidth="900"
    MinHeight="550"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#44FFFFFF" CornerRadius="3" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                To="1"
                                                Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.7"
                                                Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter
                                x:Name="Content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1.0"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.5"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Content" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Margin="0,0,0,10">
                            <Border
                                x:Name="SelectionBorder"
                                Padding="1.5"
                                CornerRadius="10"
                                Visibility="Collapsed">
                                <Border.Background>
                                    <RadialGradientBrush x:Name="GlowBrush" Center="0,0" GradientOrigin="0,0" RadiusX="0.5" RadiusY="0.5">
                                        <GradientStop Offset="0.0" Color="#FFFFFDE7" />
                                        <GradientStop Offset="0.2" Color="#FFFFD700" />
                                        <GradientStop Offset="0.5" Color="#FF8B4513" />
                                        <GradientStop Offset="0.8" Color="#FF121212" />
                                        <GradientStop Offset="1.0" Color="Transparent" />
                                    </RadialGradientBrush>
                                </Border.Background>
                                <Border Background="#FF1A1A1A" CornerRadius="9" />
                            </Border>
                            <Border
                                x:Name="ItemFrame"
                                Padding="15,15"
                                Background="#FF2A2A2A"
                                BorderBrush="#FF333333"
                                BorderThickness="1"
                                CornerRadius="10">
                                <Grid x:Name="InnerContent" Opacity="0.82">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        x:Name="StarBtn"
                                        Margin="0,0,15,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="StarBtn_Click"
                                        Content="★"
                                        FontSize="18"
                                        Foreground="#44FFFFFF"
                                        Style="{StaticResource StarButton}" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding ProjectName}" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="10"
                                            Foreground="#FF666666"
                                            Text="{Binding ProjectPath}" />
                                    </StackPanel>
                                    <StackPanel
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            x:Name="LaunchBtn"
                                            Width="80"
                                            Height="28"
                                            Margin="0,0,8,0"
                                            Background="#FF0078D4"
                                            Click="LaunchBtn_Click"
                                            Content="LAUNCH"
                                            Style="{StaticResource PillButton}" />
                                        <Button
                                            Width="80"
                                            Height="28"
                                            Background="#FF333333"
                                            Click="ManageButton_Click"
                                            Content="MANAGE"
                                            Style="{StaticResource PillButton}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Starred}" Value="True">
                                <Setter TargetName="StarBtn" Property="Foreground" Value="White" />
                                <Setter TargetName="InnerContent" Property="Opacity" Value="1.0" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Starred}" Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="PriorityPulse">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowBrush" Storyboard.TargetProperty="Opacity">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="1" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:2.4" Value="1" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:2.6" Value="0" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:3.0" Value="0" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <PointAnimationUsingKeyFrames Storyboard.TargetName="GlowBrush" Storyboard.TargetProperty="Center">
                                                <DiscretePointKeyFrame KeyTime="0:0:0.0" Value="-0.3,-0.2" />
                                                <EasingPointKeyFrame KeyTime="0:0:2.4" Value="1.4,1.3">
                                                    <EasingPointKeyFrame.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut" />
                                                    </EasingPointKeyFrame.EasingFunction>
                                                </EasingPointKeyFrame>
                                            </PointAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowBrush" Storyboard.TargetProperty="RadiusX">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0.6" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="3.5">
                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                        <CircleEase EasingMode="EaseOut" />
                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                </EasingDoubleKeyFrame>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="3.5" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0.1" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowBrush" Storyboard.TargetProperty="RadiusY">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0.8" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="2.5">
                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                        <CircleEase EasingMode="EaseOut" />
                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                </EasingDoubleKeyFrame>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="2.5" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:2.4" Value="0.2" />
                                            </DoubleAnimationUsingKeyFrames>
                                            <PointAnimationUsingKeyFrames Storyboard.TargetName="GlowBrush" Storyboard.TargetProperty="GradientOrigin">
                                                <DiscretePointKeyFrame KeyTime="0:0:0.0" Value="-0.4,-0.3" />
                                                <EasingPointKeyFrame KeyTime="0:0:2.4" Value="1.3,1.2" />
                                            </PointAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.EnterActions>
                                <MultiDataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="PriorityPulse" />
                                </MultiDataTrigger.ExitActions>
                                <Setter TargetName="SelectionBorder" Property="Visibility" Value="Visible" />
                                <Setter TargetName="ItemFrame" Property="Background" Value="Transparent" />
                                <Setter TargetName="ItemFrame" Property="BorderThickness" Value="0" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Starred}" Value="False" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                </MultiDataTrigger.Conditions>

                                <Setter TargetName="ItemFrame" Property="BorderBrush" Value="#FF005E9E" />
                                <Setter TargetName="ItemFrame" Property="BorderThickness" Value="2" />
                                <Setter TargetName="InnerContent" Property="Opacity" Value="1" />
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        Background="#FF1A1A1A"
        BorderBrush="#FF333333"
        BorderThickness="1"
        CornerRadius="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Margin="25,0"
                Background="Transparent"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <Image
                        Width="22"
                        Height="22"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        RenderOptions.BitmapScalingMode="HighQuality"
                        Source="/3d.ico" />

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="BVCC" />

                    <Border
                        Width="1"
                        Height="16"
                        Margin="14,0"
                        Background="#FF444444" />

                    <TextBlock
                        x:Name="SubHeaderText"
                        Margin="0,2,0,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="#FF888888"
                        Text="PROJECTS" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        x:Name="SETTINGS"
                        Width="35"
                        Height="30"
                        Click="SETTINGS_Click"
                        Content="⚙"
                        Style="{StaticResource TitleBarButton}" />

                    <Button
                        x:Name="MINIMISE"
                        Width="35"
                        Height="30"
                        Click="MINIMISE_Click"
                        Content="_"
                        Style="{StaticResource TitleBarButton}" />

                    <Button
                        x:Name="EXIT"
                        Width="35"
                        Height="30"
                        Click="EXIT_Click"
                        Content="✕"
                        Foreground="#FF4B4B"
                        Style="{StaticResource TitleBarButton}" />
                </StackPanel>
            </Grid>

            <Grid x:Name="AnimationGrid" Grid.Row="1">

                <ContentControl x:Name="ViewA">
                    <ContentControl.RenderTransform>
                        <TranslateTransform x:Name="TransA" X="0" />
                    </ContentControl.RenderTransform>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="55" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="15,0,25,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Height="28"
                                Margin="0,0,15,0"
                                Background="#1AFFFFFF"
                                BorderBrush="#FF333333"
                                BorderThickness="1"
                                CornerRadius="14">
                                <Grid>
                                    <TextBlock
                                        Margin="15,0"
                                        VerticalAlignment="Center"
                                        Foreground="#66FFFFFF"
                                        IsHitTestVisible="False"
                                        Text="Search projects...">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=ProjectSearchBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox
                                        x:Name="ProjectSearchBox"
                                        Padding="15,0"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CaretBrush="White"
                                        Foreground="White"
                                        TextChanged="ProjectSearchBox_TextChanged" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button
                                    Width="85"
                                    Height="28"
                                    Margin="6,0,0,0"
                                    Background="#FF333333"
                                    Click="Refresh_Click"
                                    Content="REFRESH"
                                    Style="{StaticResource PillButton}" />

                                <Button
                                    Width="90"
                                    Height="28"
                                    Margin="6,0,0,0"
                                    Background="#FF0078D4"
                                    Click="ImportProject_Click"
                                    Content="+ IMPORT"
                                    Style="{StaticResource PillButton}" />

                                <Button
                                    x:Name="CreateFromTemplateButton"
                                    Width="140"
                                    Height="28"
                                    Margin="6,0,0,0"
                                    Background="#FF0078D4"
                                    Click="CreateFromTemplate_Click"
                                    Content="+ FROM TEMPLATE"
                                    Style="{StaticResource PillButton}" />

                            </StackPanel>
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Margin="15,0,15,15"
                            Background="#FF121212"
                            BorderBrush="#FF252525"
                            BorderThickness="1"
                            CornerRadius="12">
                            <ListBox
                                x:Name="ProjectListBox"
                                Padding="12"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                ScrollViewer.CanContentScroll="False"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Border>
                    </Grid>
                </ContentControl>

                <ContentControl x:Name="ViewB" Visibility="Collapsed">
                    <ContentControl.RenderTransform>
                        <TranslateTransform x:Name="TransB" X="900" />
                    </ContentControl.RenderTransform>
                    <Border
                        Margin="15,45,15,15"
                        Background="#FF121212"
                        BorderBrush="#FF252525"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Frame x:Name="SettingsFrame" NavigationUIVisibility="Hidden" />
                    </Border>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>