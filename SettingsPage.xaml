<UserControl
    x:Class="BVCC.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter
                                x:Name="Content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1.0"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.5"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Content" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid
                            x:Name="Bg"
                            Background="Transparent"
                            SnapsToDevicePixels="true">
                            <Track
                                x:Name="PART_Track"
                                IsDirectionReversed="true"
                                IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border
                                                    x:Name="GhostBar"
                                                    Width="6"
                                                    HorizontalAlignment="Center"
                                                    Background="#33FFFFFF"
                                                    CornerRadius="3" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="GhostBar" Property="Background" Value="#AAFFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border
        Background="#FF1A1A1A"
        BorderBrush="#FF333333"
        BorderThickness="1"
        CornerRadius="15">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,20"
                Orientation="Horizontal">
                <Button
                    x:Name="BackBtn"
                    Margin="0,0,15,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BackBtn_Click"
                    Content="←"
                    FontSize="20"
                    Foreground="#88FFFFFF"
                    Style="{StaticResource TitleBarButton}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Settings" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,10,0">

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="PACKAGE REPOSITORIES" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <StackPanel>

                            <!--  HEADER ROW: title + import/export  -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  TITLE  -->
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="#FF0078D4"
                                    Text="PACKAGE REPOSITORIES" />

                                <!--  RIGHT SIDE  -->
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">

                                    <!--  SEARCH  -->
                                    <Border
                                        Width="180"
                                        Height="28"
                                        Margin="0,0,8,0"
                                        Padding="10,0"
                                        Background="#1AFFFFFF"
                                        CornerRadius="15">
                                        <TextBox
                                            x:Name="RepoSearchBox"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CaretBrush="White"
                                            FontSize="11"
                                            Foreground="White"
                                            Tag="Search repositories..."
                                            TextChanged="RepoSearchBox_TextChanged" />
                                    </Border>

                                    <!--  IMPORT  -->
                                    <Button
                                        Width="70"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        Background="#FF333333"
                                        Click="ImportRepo_Click"
                                        Content="IMPORT"
                                        FontSize="9"
                                        Style="{StaticResource PillButton}" />

                                    <!--  EXPORT  -->
                                    <Button
                                        Width="70"
                                        Height="24"
                                        Background="#FF333333"
                                        Click="ExportRepo_Click"
                                        Content="EXPORT"
                                        FontSize="9"
                                        Style="{StaticResource PillButton}" />
                                </StackPanel>
                            </Grid>
                            <!--  SEARCH BAR  -->


                            <!--  LIST  -->
                            <ListBox
                                x:Name="RepoListBox"
                                MaxHeight="220"
                                Margin="0,0,0,15"
                                Background="Transparent"
                                BorderThickness="0"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                VirtualizingStackPanel.IsVirtualizing="True">

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="12,10"
                                            Background="#FF2A2A2A"
                                            BorderBrush="#FF333333"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="White"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />

                                                <Button
                                                    Grid.Column="1"
                                                    Width="75"
                                                    Height="24"
                                                    Margin="10,0,0,0"
                                                    Background="#FF4B4B"
                                                    Click="RemoveRepo_Click"
                                                    Content="REMOVE"
                                                    FontSize="9"
                                                    Style="{StaticResource PillButton}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!--  ADD REPO  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Padding="12,0"
                                    Background="#1AFFFFFF"
                                    CornerRadius="15">
                                    <TextBox
                                        x:Name="RepoUrlInput"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CaretBrush="White"
                                        FontSize="11"
                                        Foreground="White"
                                        Tag="https://..." />
                                </Border>

                                <Button
                                    Grid.Column="1"
                                    Width="80"
                                    Height="30"
                                    Margin="10,0,0,0"
                                    Background="#FF0078D4"
                                    Click="AddRepo_Click"
                                    Content="ADD"
                                    Style="{StaticResource PillButton}" />
                            </Grid>

                        </StackPanel>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="VCC MIGRATION" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    FontSize="13"
                                    Foreground="White"
                                    Text="Import Settings from VRChat Creator Companion" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="10"
                                    Foreground="#88FFFFFF"
                                    Text="Adds all settings VCC projects to BVCC." />
                            </StackPanel>
                            <Button
                                Grid.ColumnSpan="2"
                                Height="30"
                                Margin="589,1,0,2"
                                Padding="15,0"
                                Background="#FF333333"
                                Click="ImportVCC_Click"
                                Content="IMPORT FROM VCC"
                                Style="{StaticResource PillButton}" />
                        </Grid>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="DIRECTORIES" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="10"
                                Foreground="#88FFFFFF"
                                Text="VRChat Projects Folder" />
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="ProjectPathBox"
                                    Padding="8,5"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Text="" />
                                <Button
                                    Grid.Column="1"
                                    Width="80"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    Background="#FF333333"
                                    Click="ProjectPathBoxButton_Click"
                                    Content="BROWSE"
                                    Style="{StaticResource PillButton}" />
                            </Grid>

                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="10"
                                Foreground="#88FFFFFF"
                                Text="Unity Editor Path" />
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="31*" />
                                    <ColumnDefinition Width="581*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="UnityEditorPathBox"
                                    Grid.ColumnSpan="2"
                                    Padding="8,5"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Text="" />
                                <Button
                                    Grid.Column="2"
                                    Width="80"
                                    Height="25"
                                    Margin="10,0,0,1"
                                    Background="#FF333333"
                                    Click="UnityEditorPathButton_Click"
                                    Content="BROWSE"
                                    Style="{StaticResource PillButton}" />

                            </Grid>

                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="10"
                                Foreground="#88FFFFFF"
                                Text="Local Repo Path" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="31*" />
                                    <ColumnDefinition Width="581*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="LocalRepoPathBox"
                                    Grid.ColumnSpan="2"
                                    Padding="8,5"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Text="" />
                                <Button
                                    Grid.Column="3"
                                    Width="80"
                                    Height="25"
                                    Margin="10,0,0,1"
                                    Background="#FF333333"
                                    Click="LocalRepoPathButton_Click"
                                    Content="BROWSE"
                                    Style="{StaticResource PillButton}" />

                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="CREDITS" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#88FFFFFF"
                                    Text="Developed by" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Dragonxd07" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#88FFFFFF"
                                    Text="Logo" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontSize="11"
                                    Foreground="White"
                                    TextAlignment="Right"
                                    TextWrapping="Wrap">
                                    zero_wing - Flaticon<LineBreak />
                                    meaicon - Flaticon<LineBreak />
                                    MD Badsha Meah - freeicons</TextBlock>
                            </Grid>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image
                                        Width="64"
                                        Height="64"
                                        Margin="0,0,0,10"
                                        HorizontalAlignment="Center"
                                        Source="/3d512.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        x:Name="NameText"
                                        HorizontalAlignment="Center"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="White" />
                                    <TextBlock
                                        x:Name="VersionText"
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#88FFFFFF" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">

                            <Button
                                x:Name="OpenDataButton"
                                Width="110"
                                Height="30"
                                Background="Transparent"
                                BorderBrush="#FF0078D4"
                                BorderThickness="1"
                                Click="OpenDataButton_Click"
                                Content="OPEN DATA"
                                Foreground="#FF0078D4"
                                Style="{StaticResource PillButton}" />

                            <Button
                                x:Name="ClearCacheBtn"
                                Width="110"
                                Height="30"
                                Background="Transparent"
                                BorderBrush="#FF4B4B"
                                BorderThickness="1"
                                Click="ClearCacheBtn_Click"
                                Content="CLEAR CACHE"
                                Foreground="#FF4B4B"
                                Style="{StaticResource PillButton}" />

                            <Button
                                x:Name="ResetDataBtn"
                                Width="110"
                                Height="30"
                                Background="Transparent"
                                BorderBrush="#FF4B4B"
                                BorderThickness="1"
                                Click="ResetDataBtn_Click"
                                Content="RESET DATA"
                                Foreground="#FF4B4B"
                                Style="{StaticResource PillButton}" />
                        </StackPanel>
                    </Grid>

                </StackPanel>

            </ScrollViewer>

            <StackPanel
                Grid.Row="2"
                Margin="0,15,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal" />
        </Grid>
    </Border>
</UserControl>