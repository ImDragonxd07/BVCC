<UserControl
    x:Class="BVCC.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BVCC"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="550"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <local:MultiplierConverter x:Key="MultiplierConverter" />
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <local:ActionToColorConverter x:Key="ActionToColorConverter" />
        <local:IsProgressingConverter x:Key="IsProgressingConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VersionComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#FF333333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF444444" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="ComboRoot" ClipToBounds="True">
                            <Border
                                x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <Grid ClipToBounds="True">
                                    <Border
                                        x:Name="ProgressFill"
                                        HorizontalAlignment="Left"
                                        Background="#FFAAAAAA"
                                        CornerRadius="3"
                                        Visibility="Collapsed">
                                        <Border.Width>
                                            <MultiBinding Converter="{StaticResource MultiplierConverter}">
                                                <Binding Path="InstallProgress" />
                                                <Binding ElementName="ComboRoot" Path="ActualWidth" />
                                            </MultiBinding>
                                        </Border.Width>
                                    </Border>
                                    <ToggleButton
                                        Name="ToggleButton"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        IsEnabled="{Binding IsActionProgressing, Converter={StaticResource InverseBooleanConverter}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter
                                        Margin="8,0,25,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="1"
                                        Content="{Binding SelectedItem.Version, RelativeSource={RelativeSource TemplatedParent}}"
                                        IsHitTestVisible="False" />
                                    <Path
                                        x:Name="Arrow"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="1"
                                        Data="M 0 0 L 3.5 4 L 7 0 Z"
                                        Fill="#88FFFFFF" />
                                </Grid>
                            </Border>
                            <Popup
                                Name="Popup"
                                AllowsTransparency="True"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom">
                                <Border
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    Background="#FF222222"
                                    BorderBrush="#FF444444"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <Grid ClipToBounds="True">
                                        <Border
                                            Height="3"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="0,0,3,3"
                                            Visibility="{Binding ProgressingControl, Converter={StaticResource IsProgressingConverter}, ConverterParameter=Version}">
                                            <Border.Background>
                                                <Binding Converter="{StaticResource ActionToColorConverter}" Path="CurrentAction" />
                                            </Border.Background>
                                            <Border.Width>
                                                <MultiBinding Converter="{StaticResource MultiplierConverter}">
                                                    <Binding Path="InstallProgress" />
                                                    <Binding ElementName="ComboRoot" Path="ActualWidth" />
                                                </MultiBinding>
                                            </Border.Width>
                                        </Border>
                                        <ScrollViewer
                                            MaxHeight="200"
                                            Margin="2"
                                            Panel.ZIndex="1">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ProgressingControl, Converter={StaticResource IsProgressingConverter}, ConverterParameter=Version}" Value="True" />
                                    <Condition Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ProgressFill" Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <DataTrigger Binding="{Binding IsActionProgressing}" Value="True">
                                <Setter Property="Background" Value="#FF1A1A1A" />
                                <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />

                            <Border
                                x:Name="Track"
                                Grid.Column="1"
                                Width="42"
                                Height="24"
                                Background="#FF444444"
                                CornerRadius="12"
                                Cursor="Hand">

                                <Ellipse
                                    x:Name="Thumb"
                                    Width="18"
                                    Height="18"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Left"
                                    Fill="White" />
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation
                                                Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="Margin"
                                                To="21,0,0,0"
                                                Duration="0:0:0.2" />
                                            <ColorAnimation
                                                Storyboard.TargetName="Track"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#FF0078D4"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation
                                                Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="Margin"
                                                To="3,0,0,0"
                                                Duration="0:0:0.2" />
                                            <ColorAnimation
                                                Storyboard.TargetName="Track"
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#FF444444"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter
                                x:Name="Content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="1.0"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="Content"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.5"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Content" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid
                            x:Name="Bg"
                            Background="Transparent"
                            SnapsToDevicePixels="true">
                            <Track
                                x:Name="PART_Track"
                                IsDirectionReversed="true"
                                IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border
                                                    x:Name="GhostBar"
                                                    Width="6"
                                                    HorizontalAlignment="Center"
                                                    Background="#33FFFFFF"
                                                    CornerRadius="3" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="GhostBar" Property="Background" Value="#AAFFFFFF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border
        Background="#FF1A1A1A"
        BorderBrush="#FF333333"
        BorderThickness="1"
        CornerRadius="15">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,20"
                Orientation="Horizontal">
                <Button
                    x:Name="BackBtn"
                    Margin="0,0,15,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BackBtn_Click"
                    Content="←"
                    FontSize="20"
                    Foreground="#88FFFFFF"
                    Style="{StaticResource TitleBarButton}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Settings" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,10,0">
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="PACKAGE REPOSITORIES" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Foreground="#FF0078D4"
                                    Text="PACKAGE REPOSITORIES" />

                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">

                                    <Border
                                        Width="180"
                                        Height="28"
                                        Margin="0,0,8,0"
                                        Padding="10,0"
                                        Background="#1AFFFFFF"
                                        CornerRadius="15">
                                        <TextBox
                                            x:Name="RepoSearchBox"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CaretBrush="White"
                                            FontSize="11"
                                            Foreground="White"
                                            Tag="Search repositories..."
                                            TextChanged="RepoSearchBox_TextChanged" />
                                    </Border>

                                    <Button
                                        Width="70"
                                        Height="24"
                                        Margin="0,0,6,0"
                                        Background="#FF333333"
                                        Click="ImportRepo_Click"
                                        Content="IMPORT"
                                        FontSize="9"
                                        Style="{StaticResource PillButton}" />

                                    <Button
                                        Width="70"
                                        Height="24"
                                        Background="#FF333333"
                                        Click="ExportRepo_Click"
                                        Content="EXPORT"
                                        FontSize="9"
                                        Style="{StaticResource PillButton}" />
                                    <Button
                                        Width="70"
                                        Height="24"
                                        Background="#FF333333"
                                        Click="RefetchRepos_Click"
                                        Content="REFETCH"
                                        FontSize="9"
                                        Style="{StaticResource PillButton}" />
                                </StackPanel>
                            </Grid>

                            <ListBox
                                x:Name="RepoListBox"
                                MaxHeight="220"
                                Margin="0,0,0,15"
                                Background="Transparent"
                                BorderThickness="0"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                VirtualizingStackPanel.IsVirtualizing="True">

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,8"
                                            Padding="12,10"
                                            Background="#FF2A2A2A"
                                            BorderBrush="#FF333333"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="White"
                                                    Text="{Binding Name}"
                                                    TextTrimming="CharacterEllipsis" />

                                                <Button
                                                    Grid.Column="1"
                                                    Width="75"
                                                    Height="24"
                                                    Margin="10,0,0,0"
                                                    Background="#FF4B4B"
                                                    Click="RemoveRepo_Click"
                                                    Content="REMOVE"
                                                    FontSize="9"
                                                    Style="{StaticResource PillButton}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Padding="12,0"
                                    Background="#1AFFFFFF"
                                    CornerRadius="15">
                                    <TextBox
                                        x:Name="RepoUrlInput"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        CaretBrush="White"
                                        FontSize="11"
                                        Foreground="White"
                                        Tag="https://..." />
                                </Border>

                                <Button
                                    Grid.Column="1"
                                    Width="80"
                                    Height="30"
                                    Margin="10,0,0,0"
                                    Background="#FF0078D4"
                                    Click="AddRepo_Click"
                                    Content="ADD"
                                    Style="{StaticResource PillButton}" />
                            </Grid>

                        </StackPanel>
                    </Border>
                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="VRCHAT ACCOUNT" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <StackPanel>
                            <Grid
                                x:Name="VrcLoggedInPanel"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Logged In" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="#88FFFFFF"
                                            Text="Signed in as " />
                                        <TextBlock
                                            x:Name="VrcUsernameText"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="#FF0078D4" />
                                    </StackPanel>
                                </StackPanel>
                                <Button
                                    Width="80"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#FF4B4B"
                                    BorderThickness="1"
                                    Click="VrcLogoutBtn_Click"
                                    Content="LOG OUT"
                                    FontSize="9"
                                    Style="{StaticResource PillButton}" />
                            </Grid>
                            <StackPanel x:Name="VrcLoginPanel">

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Width="80"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#88FFFFFF"
                                        Text="Email" />
                                    <Border
                                        Grid.Column="1"
                                        Padding="10,0"
                                        Background="#1AFFFFFF"
                                        CornerRadius="8">
                                        <TextBox
                                            x:Name="VrcEmailBox"
                                            Height="30"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CaretBrush="White"
                                            FontSize="11"
                                            Foreground="White" />
                                    </Border>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Width="80"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#88FFFFFF"
                                        Text="Password" />
                                    <Border
                                        Grid.Column="1"
                                        Padding="10,0"
                                        Background="#1AFFFFFF"
                                        CornerRadius="8">
                                        <PasswordBox
                                            x:Name="VrcPasswordBox"
                                            Height="30"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CaretBrush="White"
                                            FontSize="11"
                                            Foreground="White" />
                                    </Border>
                                </Grid>


                                <TextBlock
                                    x:Name="VrcLoginStatusText"
                                    Margin="0,0,0,8"
                                    FontSize="10"
                                    Foreground="#FFFF4B4B"
                                    Text=""
                                    Visibility="Collapsed" />

                                <Button
                                    x:Name="VrcLoginBtn"
                                    Height="32"
                                    Background="#FF0078D4"
                                    Click="VrcLoginBtn_Click"
                                    Content="LOG IN TO VRCHAT"
                                    Style="{StaticResource PillButton}" />

                            </StackPanel>
                            <Grid
                                x:Name="VrcTwoFactorPanel"
                                Margin="0,10,0,0"
                                Visibility="Collapsed">

                                <StackPanel>
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Two-Factor Authentication" />

                                    <TextBlock
                                        FontSize="10"
                                        Foreground="#88FFFFFF"
                                        Text="Enter your 2FA code to continue login." />

                                    <Border
                                        Margin="0,8,0,0"
                                        Padding="10,0"
                                        Background="#1AFFFFFF"
                                        CornerRadius="8">

                                        <TextBox
                                            x:Name="VrcTwoFactorBox"
                                            Height="30"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CaretBrush="White"
                                            FontSize="11"
                                            Foreground="White"
                                            MaxLength="10" />
                                    </Border>

                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                        <Button
                                            x:Name="VrcTwoFactorSubmitBtn"
                                            Width="100"
                                            Height="30"
                                            Background="#FF0078D4"
                                            Click="VrcTwoFactorSubmit_Click"
                                            Content="VERIFY"
                                            Style="{StaticResource PillButton}" />

                                        <Button
                                            Width="80"
                                            Height="30"
                                            Margin="10,0,0,0"
                                            Background="#FFFF4B4B"
                                            Click="VrcTwoFactorCancel_Click"
                                            Content="CANCEL"
                                            Style="{StaticResource PillButton}" />
                                    </StackPanel>

                                    <TextBlock
                                        x:Name="VrcTwoFactorStatus"
                                        Margin="0,5,0,0"
                                        FontSize="10"
                                        Foreground="#FFFF4B4B"
                                        Visibility="Collapsed" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,15,0,0">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Auto Login on Launch" />
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="#88FFFFFF"
                                        Text="Automatically restore your VRChat session when BVCC starts." />
                                </StackPanel>
                                <CheckBox
                                    x:Name="VrcAutoLoginCheckBox"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="VrcAutoLoginCheckBox_Click"
                                    Style="{StaticResource ToggleSwitch}" />
                            </Grid>

                        </StackPanel>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="VCC MIGRATION" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    FontSize="13"
                                    Foreground="White"
                                    Text="Import Settings from VRChat Creator Companion" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="10"
                                    Foreground="#88FFFFFF"
                                    Text="Adds all settings VCC projects to BVCC." />
                            </StackPanel>
                            <Button
                                Grid.ColumnSpan="2"
                                Height="30"
                                Margin="589,1,0,2"
                                Padding="15,0"
                                Background="#FF333333"
                                Click="ImportVCC_Click"
                                Content="IMPORT FROM VCC"
                                Style="{StaticResource PillButton}" />
                        </Grid>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="USER SETTINGS" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <StackPanel>

                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Check for Updates on Launch" />
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="#88FFFFFF"
                                        Text="Automatically check for new BVCC versions when the app starts." />
                                </StackPanel>
                                <CheckBox
                                    x:Name="CheckForUpdatesCheckBox"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="CheckForUpdatesCheckBox_Click"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleSwitch}" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Show Pre-release Packages" />
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="#88FFFFFF"
                                        Text="Display alpha and beta versions in the package browser." />
                                </StackPanel>
                                <CheckBox
                                    x:Name="ShowPreReleasesCheckBox"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="ShowPreReleasesCheckBox_Click"
                                    Style="{StaticResource ToggleSwitch}" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Open Unity After Project Create" />
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="#88FFFFFF"
                                        Text="Automatically launch Unity Editor when a new project is created." />
                                </StackPanel>
                                <CheckBox
                                    x:Name="OpenAfterProjectCreateCheckBox"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="OpenAfterProjectCreateCheckBox_Click"
                                    Style="{StaticResource ToggleSwitch}" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Auto Swipe On Backup Clone" />
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="#88FFFFFF"
                                        Text="Swipe back to the main menu after cloning a backup" />
                                </StackPanel>
                                <CheckBox
                                    x:Name="SwipeBackupClone"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="SwipeBackupClone_Click"
                                    Style="{StaticResource ToggleSwitch}" />
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="App Version" />
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="#88FFFFFF"
                                        Text="Update or roll back the application version." />
                                </StackPanel>

                                <ComboBox
                                    x:Name="AppVersionComboBox"
                                    Width="140"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    DisplayMemberPath="Version"
                                    SelectedValuePath="Version"
                                    SelectionChanged="AppVersionComboBox_SelectionChanged"
                                    Style="{StaticResource VersionComboBox}" />
                            </Grid>

                        </StackPanel>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="DIRECTORIES" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="10"
                                Foreground="#88FFFFFF"
                                Text="VRChat Projects Folder" />
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="ProjectPathBox"
                                    Padding="8,5"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Text="" />
                                <Button
                                    Grid.Column="1"
                                    Width="80"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    Background="#FF333333"
                                    Click="ProjectPathBoxButton_Click"
                                    Content="BROWSE"
                                    Style="{StaticResource PillButton}" />
                            </Grid>

                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="10"
                                Foreground="#88FFFFFF"
                                Text="Unity Editor Path" />
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="31*" />
                                    <ColumnDefinition Width="581*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="UnityEditorPathBox"
                                    Grid.ColumnSpan="2"
                                    Padding="8,5"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Text="" />
                                <Button
                                    Grid.Column="2"
                                    Width="80"
                                    Height="25"
                                    Margin="10,0,0,1"
                                    Background="#FF333333"
                                    Click="UnityEditorPathButton_Click"
                                    Content="BROWSE"
                                    Style="{StaticResource PillButton}" />
                            </Grid>

                            <TextBlock
                                Margin="0,0,0,5"
                                FontSize="10"
                                Foreground="#88FFFFFF"
                                Text="Local Repo Path" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="31*" />
                                    <ColumnDefinition Width="581*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="LocalRepoPathBox"
                                    Grid.ColumnSpan="2"
                                    Padding="8,5"
                                    Background="#1AFFFFFF"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Text="" />
                                <Button
                                    Grid.Column="3"
                                    Width="80"
                                    Height="25"
                                    Margin="10,0,0,1"
                                    Background="#FF333333"
                                    Click="LocalRepoPathButton_Click"
                                    Content="BROWSE"
                                    Style="{StaticResource PillButton}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="#FF0078D4"
                        Text="CREDITS" />
                    <Border
                        Margin="0,0,0,20"
                        Padding="15"
                        Background="#FF222222"
                        CornerRadius="10">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#88FFFFFF"
                                    Text="Developed by" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Dragonxd07" />
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#88FFFFFF"
                                    Text="Logo" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontSize="11"
                                    Foreground="White"
                                    TextAlignment="Right"
                                    TextWrapping="Wrap">
                                    zero_wing - Flaticon<LineBreak />
                                    meaicon - Flaticon<LineBreak />
                                    MD Badsha Meah - freeicons</TextBlock>
                            </Grid>
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image
                                        Width="64"
                                        Height="64"
                                        Margin="0,0,0,10"
                                        HorizontalAlignment="Center"
                                        Source="/3d512.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        x:Name="NameText"
                                        HorizontalAlignment="Center"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="White" />
                                    <TextBlock
                                        x:Name="VersionText"
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#88FFFFFF" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <StackPanel.Resources>
                                <Style BasedOn="{StaticResource PillButton}" TargetType="Button">
                                    <Setter Property="Margin" Value="0,0,10,0" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </StackPanel.Resources>

                            <Button
                                x:Name="OpenDataButton"
                                Width="110"
                                Height="30"
                                Background="Transparent"
                                BorderBrush="#FF0078D4"
                                BorderThickness="1"
                                Click="OpenDataButton_Click"
                                Content="OPEN DATA"
                                Foreground="#FF0078D4" />

                            <Button
                                x:Name="DeleteBackupsBtn"
                                Width="140"
                                Height="30"
                                Background="Transparent"
                                BorderBrush="#FF4B4B"
                                BorderThickness="1"
                                Click="DeleteBackupsBtn_Click"
                                Content="DELETE ALL BACKUPS"
                                Foreground="#FF4B4B" />

                            <Button
                                x:Name="ClearCacheBtn"
                                Width="110"
                                Height="30"
                                Background="Transparent"
                                BorderBrush="#FF4B4B"
                                BorderThickness="1"
                                Click="ClearCacheBtn_Click"
                                Content="CLEAR CACHE"
                                Foreground="#FF4B4B" />

                            <Button
                                x:Name="ResetDataBtn"
                                Width="110"
                                Height="30"
                                Margin="0"
                                Background="Transparent"
                                BorderBrush="#FF4B4B"
                                BorderThickness="1"
                                Click="ResetDataBtn_Click"
                                Content="RESET DATA"
                                Foreground="#FF4B4B" />
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <StackPanel
                Grid.Row="2"
                Margin="0,15,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal" />
        </Grid>
    </Border>
</UserControl>
