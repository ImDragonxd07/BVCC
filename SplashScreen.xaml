<Window
    x:Class="BVCC.SplashScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Loading..."
    Width="450"
    Height="250"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Background" Value="#FF1A1A1A" />
            <Setter Property="Height" Value="4" />
            <Setter Property="Width" Value="200" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" />

                            <Grid x:Name="IndeterminateRoot" Visibility="Collapsed">
                                <Rectangle
                                    x:Name="StretchBar"
                                    Width="60"
                                    Height="4"
                                    HorizontalAlignment="Left"
                                    RadiusX="2"
                                    RadiusY="2">
                                    <Rectangle.Fill>
                                        <RadialGradientBrush x:Name="GlowBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                            <GradientStop Offset="0.0" Color="#FF60CDFF" />
                                            <GradientStop Offset="0.6" Color="#FF0078D4" />
                                            <GradientStop Offset="1.0" Color="Transparent" />
                                        </RadialGradientBrush>
                                    </Rectangle.Fill>

                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="StretchScale" CenterX="30" ScaleX="1" />
                                            <TranslateTransform x:Name="StretchTranslate" X="-60" />
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="IndeterminateRoot" Property="Visibility" Value="Visible" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="GlowSwoosh">
                                        <Storyboard RepeatBehavior="Forever">

                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="StretchBar" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="-80" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.4,0 0.6,1"
                                                    KeyTime="0:0:2.0"
                                                    Value="220" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:2.8" Value="220" />
                                            </DoubleAnimationUsingKeyFrames>

                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="StretchBar" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                                <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.2" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.1,0.9 0.2,1.0"
                                                    KeyTime="0:0:1.0"
                                                    Value="2.5" />
                                                <SplineDoubleKeyFrame
                                                    KeySpline="0.7,0 1,0.3"
                                                    KeyTime="0:0:2.0"
                                                    Value="0.2" />
                                                <LinearDoubleKeyFrame KeyTime="0:0:2.8" Value="0.2" />
                                            </DoubleAnimationUsingKeyFrames>

                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GlowBrush" Storyboard.TargetProperty="RadiusX">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.5" />
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="1.5">
                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                        <CircleEase EasingMode="EaseOut" />
                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                </EasingDoubleKeyFrame>
                                                <LinearDoubleKeyFrame KeyTime="0:0:2.0" Value="0.5" />
                                            </DoubleAnimationUsingKeyFrames>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        Background="#FF1A1A1A"
        BorderBrush="#FF333333"
        BorderThickness="1"
        CornerRadius="15">

        <Grid Margin="30">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                    <Border
                        Width="60"
                        Height="60"
                        Background="#FF1F1F1F"
                        CornerRadius="12">
                        <Image
                            Margin="12"
                            Source="/3d512.png"
                            Stretch="Uniform" />
                    </Border>

                    <TextBlock
                        Margin="20,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="32"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="BVCC" />
                </StackPanel>

                <ProgressBar
                    x:Name="LoadingBar"
                    Width="200"
                    Height="4"
                    Margin="0,40,0,0"
                    IsIndeterminate="True"
                    Style="{StaticResource ModernProgressBar}" />

                <TextBlock
                    x:Name="LoadingStatus"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontSize="10"
                    Foreground="#FF555555"
                    Text="Initialising..." />
            </StackPanel>
        </Grid>
    </Border>
</Window>