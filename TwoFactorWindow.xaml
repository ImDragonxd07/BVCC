<Window
    x:Class="BVCC.TwoFactorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VRChat Verification"
    Width="300"
    Height="150"
    WindowStartupLocation="CenterScreen">

    <StackPanel Margin="10">
        <TextBlock Margin="0,0,0,10" Text="Enter the code sent to your email:" />

        <TextBox
            Name="CodeBox"
            Height="25"
            Margin="0,0,0,10"
            KeyDown="CodeBox_KeyDown" />

        <Button
            Height="30"
            Click="Verify_Click"
            Content="Verify" />
    </StackPanel>
</Window>